36880>>>    Procedure SetActionButtons
36883>>>        tWebNavigateData NavigateData
36883>>>        tWebNavigateData NavigateData
36883>>>        Boolean bHasRecord
36883>>>        Handle hoDD
36883>>>
36883>>>        Get Server to hoDD
36884>>>        Get GetNavigateData to NavigateData
36885>>>        Get HasRecord of hoDD to bHasRecord
36886>>>
36886>>>        // let's hide all buttons and then Show the ones we want
36886>>>        WebSet pbRender of oEditBtn to False
36887>>>        WebSet pbRender of oSaveBtn to False
36888>>>        WebSet pbRender of oCancelChangesBtn to False
36889>>>        WebSet pbRender of oDeleteBtn to False
36890>>>
36890>>>        If (NavigateData.bReadOnly) Begin
36892>>>            WebSet pbRender of oEditBtn to True
36893>>>        End
36893>>>>
36893>>>        Else Begin
36894>>>            WebSet pbRender of oSaveBtn to True
36895>>>            WebSet pbRender of oCancelChangesBtn to True
36896>>>            WebSet pbRender of oDeleteBtn to bHasRecord
36897>>>        End
36897>>>>
36897>>>    End_Procedure
36898>>>
36898>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
36901>>>        // Close after save
36901>>>        Send NavigateClose Self
36902>>>    End_Procedure
