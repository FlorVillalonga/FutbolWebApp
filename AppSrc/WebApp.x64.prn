37499>>>        Boolean bHasRecord
37499>>>        Handle hoDD
37499>>>
37499>>>        Get Server to hoDD
37500>>>        Get GetNavigateData to NavigateData
37501>>>        Get HasRecord of hoDD to bHasRecord
37502>>>
37502>>>        // let's hide all buttons and then Show the ones we want
37502>>>        WebSet pbRender of oEditBtn to False
37503>>>        WebSet pbRender of oSaveBtn to False
37504>>>        WebSet pbRender of oCancelChangesBtn to False
37505>>>        WebSet pbRender of oDeleteBtn to False
37506>>>
37506>>>        If (NavigateData.bReadOnly) Begin
37508>>>            WebSet pbRender of oEditBtn to True
37509>>>        End
37509>>>>
37509>>>        Else Begin
37510>>>            WebSet pbRender of oSaveBtn to True
37511>>>            WebSet pbRender of oCancelChangesBtn to True
37512>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37513>>>        End
37513>>>>
37513>>>    End_Procedure
