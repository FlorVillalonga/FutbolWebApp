36862>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
36865>>>        Case Begin
36865>>>            Case (NavigateData.eNavigateType = nfFromMain)
36867>>>                // If from main, this is a propbably a main file Select to Zoom.
36867>>>                Case Break
36868>>>
36868>>>            Case (NavigateData.eNavigateType = nfFromParent)
36871>>>                // If from parent, this is a constrained drill down.
36871>>>                Case Break
36872>>>
36872>>>            Case (NavigateData.eNavigateType = nfFromChild)
36875>>>                // If from child, this is a probably a parent Zoom from a Zoom.
36875>>>                Case Break
36876>>>
36876>>>            Case Else // must be nfUndefined
36876>>>
36876>>>        Case End
36876>>>
36876>>>        Send SetActionButtons
36877>>>
36877>>>    End_Procedure
36878>>>
36878>>>End_Object 
