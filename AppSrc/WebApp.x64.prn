36911>>>        Case Begin
36911>>>            Case (NavigateData.eNavigateType = nfFromMain)
36913>>>                // If from main, this is a propbably a main file Select to Zoom.
36913>>>                Case Break
36914>>>
36914>>>            Case (NavigateData.eNavigateType = nfFromParent)
36917>>>                // If from parent, this is a constrained drill down.
36917>>>                Case Break
36918>>>
36918>>>            Case (NavigateData.eNavigateType = nfFromChild)
36921>>>                // If from child, this is a probably a parent Zoom from a Zoom.
36921>>>                Case Break
36922>>>
36922>>>            Case Else // must be nfUndefined
36922>>>
36922>>>        Case End
36922>>>
36922>>>        Send SetActionButtons
36923>>>
36923>>>    End_Procedure
36924>>>
36924>>>End_Object 
