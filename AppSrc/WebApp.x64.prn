36834>>>    Procedure SetActionButtons
36837>>>        tWebNavigateData NavigateData
36837>>>        tWebNavigateData NavigateData
36837>>>        Boolean bHasRecord
36837>>>        Handle hoDD
36837>>>
36837>>>        Get Server to hoDD
36838>>>        Get GetNavigateData to NavigateData
36839>>>        Get HasRecord of hoDD to bHasRecord
36840>>>
36840>>>        // let's hide all buttons and then Show the ones we want
36840>>>        WebSet pbRender of oEditBtn to False
36841>>>        WebSet pbRender of oSaveBtn to False
36842>>>        WebSet pbRender of oCancelChangesBtn to False
36843>>>        WebSet pbRender of oDeleteBtn to False
36844>>>
36844>>>        If (NavigateData.bReadOnly) Begin
36846>>>            WebSet pbRender of oEditBtn to True
36847>>>        End
36847>>>>
36847>>>        Else Begin
36848>>>            WebSet pbRender of oSaveBtn to True
36849>>>            WebSet pbRender of oCancelChangesBtn to True
36850>>>            WebSet pbRender of oDeleteBtn to bHasRecord
36851>>>        End
36851>>>>
36851>>>    End_Procedure
36852>>>
36852>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
36855>>>        // Close after save
36855>>>        Send NavigateClose Self
36856>>>    End_Procedure
