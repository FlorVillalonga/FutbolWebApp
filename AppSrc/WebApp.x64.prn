38210>>>        Get HasRecord of hoDD to bHasRecord
38211>>>
38211>>>        WebSet pbRender of oEditBtn to False
38212>>>        WebSet pbRender of oSaveBtn to False
38213>>>        WebSet pbRender of oCancelChangesBtn to False
38214>>>        WebSet pbRender of oDeleteBtn to False
38215>>>
38215>>>        If (NavigateData.bReadOnly) Begin
38217>>>            WebSet pbRender of oEditBtn to True
38218>>>        End
38218>>>>
38218>>>        Else Begin
38219>>>            WebSet pbRender of oSaveBtn to True
38220>>>            WebSet pbRender of oCancelChangesBtn to True
38221>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38222>>>        End
