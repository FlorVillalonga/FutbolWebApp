37501>>>
37501>>>        // let's hide all buttons and then Show the ones we want
37501>>>        WebSet pbRender of oEditBtn to False
37502>>>        WebSet pbRender of oSaveBtn to False
37503>>>        WebSet pbRender of oCancelChangesBtn to False
37504>>>        WebSet pbRender of oDeleteBtn to False
37505>>>
37505>>>        If (NavigateData.bReadOnly) Begin
37507>>>            WebSet pbRender of oEditBtn to True
