38154>>>        WebSet pbRender of oEditBtn to False
38155>>>        WebSet pbRender of oSaveBtn to False
38156>>>        WebSet pbRender of oCancelChangesBtn to False
38157>>>        WebSet pbRender of oDeleteBtn to False
38158>>>
38158>>>        If (NavigateData.bReadOnly) Begin
38160>>>            WebSet pbRender of oEditBtn to True
38161>>>        End
38161>>>>
38161>>>        Else Begin
38162>>>            WebSet pbRender of oSaveBtn to True
38163>>>            WebSet pbRender of oCancelChangesBtn to True
38164>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38165>>>        End
38165>>>>
