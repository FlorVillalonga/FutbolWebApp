37048>>>                // If from main, this is a probably a main-file lookup from a Zoom
37048>>>                WebSet pbRender of oDetailButton to False
37049>>>                Case Break
37050>>>
37050>>>            Case Else // must be nfUndefined
37050>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37050>>>
37050>>>        Case End
37050>>>
37050>>>    End_Procedure
