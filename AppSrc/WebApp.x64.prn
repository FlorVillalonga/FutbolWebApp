37102>>>                Case Break
37103>>>
37103>>>            Case Else // must be nfUndefined
37103>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37103>>>
37103>>>        Case End
37103>>>
37103>>>    End_Procedure
